# Network configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployer identity (stellar keys name, must exist locally)
# Run: stellar keys generate deployer --network testnet --fund
STELLAR_DEPLOYER_KEY=deployer

# AtomicSwap initialization parameters (required)
ATOMIC_SWAP_ADMIN=          # Stellar address of the contract admin
ATOMIC_SWAP_FEE_RECIPIENT=  # Stellar address that receives protocol fees
ATOMIC_SWAP_FEE_BPS=0       # Fee in basis points (0 = no fee, 100 = 1%)
ATOMIC_SWAP_CANCEL_DELAY_SECS=3600  # Seconds before a pending swap can be cancelled
ATOMIC_SWAP_DISPUTE_WINDOW_LEDGERS= # Optional: override default dispute window (17280 ledgers ~24h)

# Contract addresses (populated automatically after deployment)
CONTRACT_ATOMIC_SWAP=
CONTRACT_IP_REGISTRY=
CONTRACT_ZK_VERIFIER=

# IPFS configuration
IPFS_GATEWAY=https://gateway.pinata.cloud
PINATA_API_KEY=

# Frontend configuration
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
